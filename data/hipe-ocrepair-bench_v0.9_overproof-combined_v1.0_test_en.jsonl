], [1399, 1430], [1431, 1462], [1463, 1496], [1497, 1533], [1534, 1561], [1562, 1595], [1596, 1629], [1630, 1667], [1668, 1703], [1704, 1735], [1736, 1773], [1774, 1808], [1809, 1838], [1839, 1846], [1847, 1877], [1878, 1914], [1915, 1950], [1951, 1987], [1988, 2023], [2024, 2031], [2032, 2065], [2066, 2103], [2104, 2137], [2138, 2173], [2174, 2181], [2182, 2199], [2200, 2235], [2236, 2271], [2272, 2304], [2305, 2340], [2341, 2374], [2375, 2410], [2411, 2445], [2446, 2479], [2480, 2516], [2517, 2524], [2525, 2558], [2559, 2594], [2595, 2629], [2630, 2666], [2667, 2700], [2701, 2734], [2735, 2768], [2769, 2807], [1169, 1174], [2814, 2848], [2849, 2885], [2886, 2920], [2921, 2955], [2956, 2991], [2992, 3011]], \"sentence_offsets\": [[0, 112], [113, 136], [137, 139], [140, 213], [214, 349], [350, 410], [411, 428], [429, 455], [456, 537], [537, 699], [700, 820], [821, 953], [954, 1173], [1174, 1195], [1196, 1415], [1416, 1560], [1561, 1614], [1615, 1692], [1693, 1845], [1846, 2030], [2031, 2102], [2103, 2180], [2181, 2198], [2199, 2292], [2293, 2414], [2415, 2523], [2524, 2628], [2629, 2812], [2813, 2927], [2928, 3010]], \"num_tokens\": 428, \"num_chars\": 3011, \"quality_report\": {\"ocr_quality_score\": 0.9, \"cer\": 0.055592, \"wer\": 0.219907, \"nb_char_substitutions\": 98, \"nb_char_deletions\": 50, \"nb_char_insertions\": 21}}, \"ocr_postcorrection_output\": {\"transcription_unit\": \"None\", \"ocr_postcorrection_system\": \"None\", \"num_tokens\": -1, \"num_chars\": -1, \"quality_report\": {\"ocr_quality_score\": -1, \"cer\": -1, \"wer\": -1, \"nb_char_substitutions\": -1, \"nb_char_deletions\": -1, \"nb_char_insertions\": -1}}}"],"stylingDirectives":null,"colorizedLines":["{\u0026quot;document_metadata\u0026quot;: {\u0026quot;document_id\u0026quot;: \u0026quot;13023000\u0026quot;, \u0026quot;primary_dataset_name\u0026quot;: \u0026quot;overproof-combined\u0026quot;, \u0026quot;primary_dataset_filename\u0026quot;: \u0026quot;data/03_curated/overproof/dataset2/rawTextAndHumanCorrectionAndOverproofCorrectionTriples/allArticles.corrected.txt\u0026quot;, \u0026quot;primary_dataset_version\u0026quot;: \u0026quot;v1.0\u0026quot;, \u0026quot;primary_dataset_license\u0026quot;: \u0026quot;Very likely public domain, but not explicitly stated in original source.\u0026quot;, \u0026quot;primary_dataset_url\u0026quot;: \u0026quot;https://overproof.projectcomputing.com/evaluation\u0026quot;, \u0026quot;benchmark_dataset_name\u0026quot;: \u0026quot;hipe-ocrepair-bench-overproof\u0026quot;, \u0026quot;benchmark_dataset_doi\u0026quot;: \u0026quot;https://doi.org/10.5281/zenodo.18824299\u0026quot;, \u0026quot;benchmark_dataset_split\u0026quot;: \u0026quot;all\u0026quot;, \u0026quot;document_type\u0026quot;: \u0026quot;newspaper\u0026quot;, \u0026quot;date\u0026quot;: \u0026quot;1859\u0026quot;, \u0026quot;language\u0026quot;: \u0026quot;en\u0026quot;, \u0026quot;publication_title\u0026quot;: \u0026quot;The Sydney Morn aid\u0026quot;, \u0026quot;transcription_unit_scope\u0026quot;: \u0026quot;article\u0026quot;, \u0026quot;segmentation_origin_article\u0026quot;: \u0026quot;primary-dataset - legacy\u0026quot;, \u0026quot;segmentation_origin_lines\u0026quot;: \u0026quot;primary-dataset - legacy\u0026quot;, \u0026quot;segmentation_origin_sentences\u0026quot;: \u0026quot;benchmark - automatic\u0026quot;}, \u0026quot;ground_truth\u0026quot;: {\u0026quot;transcription_unit\u0026quot;: \u0026quot;MERCANTILE AND MONEY ARTICLE.\\nMonday Evening.\\nMessrs. Mort and Co. sold, to-day, by auction,\\non the ground, at Collingwood, the following\\nportion of the Collingwood estate :—-Colling¬\\nwood House and grounds, out-offices, garden,\\n\u0026amp;c., comprising 23 acres of land, for £1350, to\\nMr. Gillespie ; four building allotments, with\\nfrontage to the Great Southern Road, at from\\n3s 9d. to 6s. per foot; allotments section\\n7 and 8, opposite Collingwood House,\\nto Mr. Gillespie, at 5s, per foot.\\nThey also sold, after the sale, the Steam Flour\\nMills, miller\u0026#39;s cottage, \u0026amp;c., for £2000, to Mr.\\nHenry Moore ; the butcher\u0026#39;s shop for £315, to\\nMr. Bond. The attendance of buyers was good,\\nand the bidding for some lots was spirited.\\nAfter the sale several offers were made at im¬\\nproved prices for the allotments of land and\\nsmall farms, and no doubt we shall have to re¬\\ncord sales privately of a large portion of this\\nestate. The total amount realised to-day was\\n£4370 3s. 6d.\\nThe adjourned meeting with reference to the\\nproposed company for the purchase of the\\nAlpacas, will be held to-morrow, at 2 o\u0026#39;clock.\\nThe Northern Escort arrived to-day from the\\nRocky River Diggings, with 1945 ounces of\\ngold-dust.\\nWe append Messrs. Schmidt, Kastermann,\\nand Co.\u0026#39;s Circular, dated Penang, 24th January,\\n1859:\\nProduce -All our principal articles of exports have been in\\ngreat demand, chiefly for America, throughout the month past,\\nand, supplies falling short, an advance on former rates has in\\nmany instances been submitted to.\\n- Tin -Large purchases for the American markets at the end of\\nlast and beginning of this month at from 27¼ dollars to 27½ dol¬\\nlars per picul. The season for heavy supplies from Junk Ceylon\\nis now nearly over ; the market has been further influenced by\\nfavourable accounts from India and England and the declining\\nrate of Exchange, and prices have gradually gone up to 28 dol¬\\nlars 60 cents per picul, which is the rate paid this day.\\nSugar -Considerable shipments to London, per Pilgrim and\\nGolconda, for planters\u0026#39; account. Local sales for India and Singa¬\\npore at 5 dollars to 74 dollars for white, 4¼ dollars to 5½ dollars\\nfor yellow, and 3 dollars to 3½ dollars for brown.\\nRum. - The Golconda takes a large quantity to England for\\nplanters\u0026#39; account. Sales for the Singapore and China market at\\n50 to 55 cents per gallon, 30 to 35 per cent, over proof\\nPepper.- There has been much competition for the few lots\\ncoming to market between the vessels loading for America, and\\nprices have been forced up to 7 dollars 90 cents per picul. for West\\nCoast, and 7 dollars 65 cents per picul for East Coast. A small lot\\nof Truery of fair quality sold at 7 dollars 77½ cents per picul. The\\npressing demand for America being satisfied, a decline of rates\\nmay now be looked forward to. White pepper is scarce, and paid\\nas high as 14½ dollars per picul.\\nOnch.- None in market.\\nGutta Percha.- In great demand. A small parcel has been pur¬\\nchased for Singapore at 23 dollars per picul.\\nIndia Rubber. - Is much wanted, and purchased as it arrives at\\n19½ dollars to 20 dollars per picul.\\nHides - Continue in demand for America ; sales of Buffalo at\\n7 dollars to 7¼, and cow at 10 dollars to 10¼ per picul.\\nHorns. - In demand at 7 dollars to 7¼ dollars per picul. Sup¬\\nplies very limited.\\nSpices. - Nutmegs are selling at 41 dollars per picul, 110 to the\\nlb. Mace 34 dollars per picul. Penang cloves 23 dollars per\\npicul, crop very small. Zanzibar cloves 7½ dollars per picul.\\nGum Benjamin.- Purchases of No 2 quality at 17 dollars to l8\\ndollars per picul. No supplies of No. 1.\\nBetelnut. - Stocks have been lightened by shipments to Cal¬\\ncutta ; holders are asking now 5¼ dollars per bhar, for good\\nquality.\\nRattans.- In demand ; best Perak paid as high as 3½ dollars\\nper pical.\\nRice.-The bulk of the new crop of Rangoon is now reaching\\nour market and prices have given way. We quote New Cargo at\\n42 dollars to 43 dollars; White Rangoon at 70 dollars, and White\\nQuedah at 85 dollars per enyan. Old rice is unsaleable.\\nOpium -Benares 793 dollars per chest, and expected to go even\\nhigher. The last sale of Turkey was at 950 dollars per picul.\\nExchanges. - Transactions have been very limited, sales are\\nreported at 4s. 7¼d. six months sight on London. On Calcutta\\n120 per cent, for short, and 213 per cent, for 30 days\u0026#39; sight. Com¬\\npany\u0026#39;s rupee shares and held at 210 for 100 dollars.\\nThe following is taken from Messrs. Halliday,\\nWise, and Co.\u0026#39;s Market Report, dated Foochow,\\n24th January :\\nExports.- A considerable business has been done in tea during\\nthe past fortnight, in consequence of teamen having given way in\\ntheir demands, and purchases of medium Sinchuen kinds have\\nbeen made at 1 to 2 £s. reduction on former rates.\\nThe arrivals have again been heavy, amounting to 22,000 chests\\nof congou, and present stock of that description is estimated at\\n15,000 chests.\\nThe settlements of the fortnight are reported at\\n20,000 chests of congou. 2000 chests souchong.\\n1,280 chests of Ningehow congou. 3400 half-chests oolong.\\nOur present quotations are\\nT. T.\\nCongou-common, low, and dusty .. 12 to 14 per peel., short\\nGood, sound, common .. 15 to 16 ditto\\nCommon to medium, Sinchuen\\nkinds .. .. 17 to 21 ditto\\nKaisow kinds. . .. 22 to 25 ditto;\\nMangshowe .. .. 23½ to 24 ditto\\nSouchong - common to medium .. l6 to 24 ditto\\nOolong - common to fine .. .. 15½j to 24 ditto\\nThe only departure has been Magniperb, to London, making\\nthe export to United Kingdom from this port 9,551,000 lbs.,\\nagainst 14,000,000 lbs., at same date last season.\\nThe vessels on the berth are, Serrata and Ringleader, both for\\nLondon, and the former fully engaged at £3 per ton.\u0026quot;, \u0026quot;line_offsets\u0026quot;: [[0, 29], [30, 45], [46, 92], [93, 137], [138, 183], [184, 228], [229, 276], [277, 323], [324, 368], [369, 411], [412, 448], [449, 483], [484, 531], [532, 579], [580, 625], [626, 670], [671, 714], [715, 761], [762, 806], [807, 853], [854, 901], [902, 946], [947, 960], [961, 1004], [1005, 1045], [1046, 1092], [1093, 1136], [1137, 1178], [1179, 1189], [1190, 1228], [1229, 1276], [1277, 1282], [1283, 1342], [1343, 1404], [1405, 1467], [1468, 1501], [1502, 1563], [1564, 1628], [1629, 1691], [1692, 1754], [1755, 1815], [1816, 1878], [1879, 1936], [19